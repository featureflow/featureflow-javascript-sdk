{
  "name": "featureflow-client",
  "version": "2.2.0",
  "description": "Featureflow JavaScript/TypeScript Client SDK",
  "author": "Featureflow <contact@featureflow.io>",
  "license": "Apache-2.0",
  "keywords": [
    "featureflow",
    "feature",
    "analytics",
    "client",
    "feature flag",
    "feature toggle",
    "release",
    "typescript"
  ],
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/featureflow/featureflow-javascript-sdk.git"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.esm.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc --noEmit",
    "example": "webpack serve --config ./example/webpack.config.js --mode development",
    "example:ts": "cross-env ENTRY=example.ts webpack serve --config ./example/webpack.config.js --mode development"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@jest/globals": "^30.2.0",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/base64-js": "^1.3.4",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "babel-loader": "^10.0.0",
    "cross-env": "^10.1.0",
    "gzip-size": "^6.0.0",
    "html-webpack-plugin": "^5.6.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "pretty-bytes": "^6.1.1",
    "rollup": "^4.9.0",
    "ts-jest": "^29.4.5",
    "ts-loader": "^9.5.4",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "base64-js": "^1.5.1",
    "js-cookie": "^3.0.5",
    "mitt": "^3.0.1"
  }
}
